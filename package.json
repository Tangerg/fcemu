{
  "name": "fcemu-workspace",
  "private": true,
  "version": "0.1.0",
  "license": "UNLICENSED",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "vite": "8.1.4"
  },
  "scripts": {
    "dev": "yarn workspace @fcemu/ui dev",
    "build": "yarn workspace @fcemu/core build && yarn workspace @fcemu/ui build",
    "benchmark:core": "yarn workspace @fcemu/core benchmark",
    "conformance:rom": "yarn workspace @fcemu/core conformance:rom",
    "conformance:accuracy-coin": "yarn workspace @fcemu/core conformance:accuracy-coin",
    "conformance:mmc1": "yarn workspace @fcemu/core conformance:mmc1",
    "conformance:mapper34": "yarn workspace @fcemu/core conformance:mapper34",
    "conformance:oam-bus": "yarn workspace @fcemu/core conformance:oam-bus",
    "conformance:pal-apu": "yarn workspace @fcemu/core conformance:pal-apu",
    "conformance:cpu": "yarn conformance:rom",
    "preview": "yarn workspace @fcemu/ui preview",
    "typecheck": "yarn workspaces run typecheck",
    "test": "yarn workspaces run test",
    "lint": "oxlint packages --deny-warnings",
    "lint:fix": "oxlint packages --fix --deny-warnings",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "check:layers": "node scripts/check-layers.mjs",
    "check:circular": "node scripts/check-circular.mjs",
    "quality": "yarn typecheck && yarn lint && yarn format:check && yarn test && yarn knip && yarn check:circular && yarn check:layers"
  },
  "devDependencies": {
    "knip": "^6.26.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
